# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local — it is in .gitignore.

# Supabase — get these from `supabase start` (local) or your Supabase project dashboard (prod)
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=your-local-anon-key-here

# Note: SUPABASE_SERVICE_ROLE_KEY is for Edge Functions only — never prefix with VITE_
# Set it via: supabase secrets set SUPABASE_SERVICE_ROLE_KEY=your-key
